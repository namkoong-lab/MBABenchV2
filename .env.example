# Copy this file to `.env`, fill in the values, then load it with:
#     source .env
#
# `.env` is git-ignored so your real credentials are never committed.

# Neon Postgres connection string for the BizbenchV2 database.
# Get this from the Neon console (Connect -> connection string, BizbenchV2 db).
export DATABASE_URL="postgresql://USER:PASSWORD@HOST/BizbenchV2?sslmode=require"

# Gemini API key (https://ai.google.dev/).
export GEMINI_API_KEY="your-gemini-api-key"

# AWS credentials are read from the standard locations (~/.aws/credentials or
# AWS_* environment variables), not from this file. Make sure the active
# profile can read and write the biz-bench S3 bucket:
#     aws sts get-caller-identity
#     aws s3 ls s3://biz-bench/
