[Unit]
Description=gui-agents provider-login probe (one-shot)
After=network-online.target xvfb.service gui-agents-worker.service
Wants=network-online.target
Requires=xvfb.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/gui-agents-master
Environment=PYTHONPATH=/opt/gui-agents-master
Environment=GUI_AGENTS_STATE_DIR=/var/lib/gui-agents
Environment=DISPLAY=:99
EnvironmentFile=/etc/gui-agents/secrets.env
ExecStart=/usr/bin/python3 -m infra.worker.auth_probe
# Don't restart on failure — the timer will re-fire us. A persistent
# failure means "not logged in", which is the signal we want to surface.
SuccessExitStatus=0 1
